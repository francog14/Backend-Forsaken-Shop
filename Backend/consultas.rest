###########################################################
# 1. MICROSERVICIO DE CATEGORÍA (Puerto 7070)
###########################################################

### GET - Obtener todas las categorías
GET http://localhost:7070/categorias
Content-Type: application/json

### GET - Obtener categoría por ID
GET http://localhost:7070/categorias/1
Content-Type: application/json

### POST - Crear nueva categoría
POST http://localhost:7070/categorias
Content-Type: application/json

{
  "nombre_categoria": "Camisetas"
}

### PUT - Actualizar categoría
PUT http://localhost:7070/categorias
Content-Type: application/json

{
  "id_categoria": 1,
  "nombre_categoria": "Camisetas Premium"
}

### DELETE - Eliminar categoría
DELETE http://localhost:7070/categorias/1
Content-Type: application/json

